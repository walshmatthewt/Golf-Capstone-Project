data("Boston")
predictors = setdiff(names(Boston), "crim")
# Store p-values
results = data.frame(Predictor = predictors, Pvalue = NA)
# Loop through predictors
for (i in 1:length(predictors)) {
formula = as.formula(paste("crim ~", predictors[i]))
model = lm(formula, data = Boston)
results$Pvalue[i] = summary(model)$coefficients[2, 4]
}
# Show predictors ordered by significance
results[order(results$Pvalue), ]
data("Boston")
predictors = setdiff(names(Boston), "crim")
# Table to store coefficient + p-value
results = data.frame(
Predictor = predictors,
Coefficient = NA,
Pvalue = NA
)
# Loop through predictors
for (i in 1:length(predictors)) {
formula = as.formula(paste("crim ~", predictors[i]))
model = lm(formula, data = Boston)
sum = summary(model)$coefficients
results$Coefficient[i] = sum[2, 1]     # slope
results$Pvalue[i]      = sum[2, 4]     # p-value
}
# Show predictors ordered by significance
results[order(results$Pvalue), ]
# Show only significant predictors
subset(results, Pvalue < 0.05)
